MONGO_URI=mongodb://127.0.0.1:27017/youtube-clone
JWT_SECRET=youtubeclone_jwt_secret_key_2026_antigravity

# Scalable Video Storage (S3-Compatible: Cloudflare R2 / AWS / Backblaze / MinIO)
S3_BUCKET=your_bucket_name
S3_REGION=auto
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_PUBLIC_DOMAIN=https://pub-xxxxxx.r2.deve
PORT=5000
NODE_ENV=development
